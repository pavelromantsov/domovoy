{
  "info": {
    "name": "Domovoy Auth Service API",
    "description": "API endpoints for the refactored Domovoy Authentication Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/auth/refresh",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Device Management",
      "item": [
        {
          "name": "Register Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"networkDeviceId\": \"sensor_001\",\n  \"roomId\": null\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/devices/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "devices", "register"]
            }
          }
        },
        {
          "name": "Revoke Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/devices/sensor_001/revoke",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "devices", "sensor_001", "revoke"]
            }
          }
        },
        {
          "name": "Rotate Device Secret",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/devices/sensor_001/rotate-secret",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "devices", "sensor_001", "rotate-secret"]
            }
          }
        }
      ]
    },
    {
      "name": "Device Authentication",
      "item": [
        {
          "name": "Authenticate Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"networkDeviceId\": \"sensor_001\",\n  \"secret\": \"device_secret_from_registration\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/device-auth/authenticate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "device-auth", "authenticate"]
            }
          }
        }
      ]
    }
  ]
}
